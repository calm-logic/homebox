# =============================================================================
# Homebox Host Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Your root domain — all projects route as <project>.HOMEBOX_DOMAIN
HOMEBOX_DOMAIN=example.com

# Traefik dashboard credentials (generate with: htpasswd -nb admin <password>)
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$xyz$$hashedpassword

# Path on the Host where the Traefik dynamic config lives
TRAEFIK_DYNAMIC_CONF_DIR=/opt/homebox/traefik
